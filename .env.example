# The Odds API key — get yours at https://the-odds-api.com/
ODDS_API_KEY=your_api_key_here

# Multi-sport configuration (comma-separated)
# Supported: basketball_nba, americanfootball_nfl, baseball_mlb, icehockey_nhl,
#   soccer_epl, soccer_uefa_champs_league, tennis_atp, mma_mixed_martial_arts
# Free tier: start with 3 sports to stay within API quota
SPORTS=basketball_nba,americanfootball_nfl,baseball_mlb

# Bookmakers to track (comma-separated). Leave empty for all available.
BOOKMAKERS=

# Data directories
DATA_DIR=data
RAW_DIR=data/raw
PROCESSED_DIR=data/processed
ANALYTICS_DIR=data/analytics

# Analytics thresholds
EV_THRESHOLD=0.02

# Freshness filter (minutes)
FRESHNESS_MINUTES=5

# Strict freshness mode
# true = exclude stale data (production)
# false = allow old data for demo/dashboard
STRICT_FRESHNESS=true
